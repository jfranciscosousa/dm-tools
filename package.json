{
  "name": "dm-tools",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:vercel": "pnpm dlx vercel env pull && vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "playwright test",
    "ci": "pnpm run lint && pnpm run check && pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@playwright-testing-library/test": "^4.5.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/sanitize-html": "^2.16.1",
    "@types/showdown": "^2.0.6",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "daisyui": "^5.5.19",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.104",
    "ai": "6.0.168",
    "dexie": "^4.4.2",
    "dexie-observable": "4.0.1-beta.13",
    "encoding": "^0.1.13",
    "lodash-es": "^4.18.1",
    "sanitize-html": "^2.17.3",
    "showdown": "^2.1.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  }
}
