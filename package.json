{
  "name": "dm-tools",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:vercel": "pnpm dlx vercel env pull && vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "playwright test",
    "ci": "pnpm run lint && pnpm run check && pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@playwright-testing-library/test": "^4.5.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/sanitize-html": "^2.16.1",
    "@types/showdown": "^2.0.6",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "daisyui": "^5.5.19",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.80",
    "ai": "6.0.138",
    "dexie": "^4.3.0",
    "dexie-observable": "4.0.1-beta.13",
    "encoding": "^0.1.13",
    "lodash-es": "^4.17.23",
    "sanitize-html": "^2.17.2",
    "showdown": "^2.1.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  }
}
